# =============================================================================
# Verge — Docker Compose environment
# =============================================================================
# Copy to `deploy/.env` before `make up`.
# For the full variable list (LLM, Cognee, Speechmatics, etc.) see the repo
# root `.env.example` — copy both files and keep secrets in sync.
# =============================================================================

# ── Postgres + PostGIS (used by compose service `postgres`) ─────────────────
POSTGRES_DB=verge
POSTGRES_USER=verge
POSTGRES_PASSWORD=

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_PASSWORD=

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=verge
MINIO_SECRET_KEY=

# ── Stream bus (host-side clients) ────────────────────────────────────────────
REDPANDA_BROKERS=localhost:19092

# ── TimescaleDB (host-side DSN) ───────────────────────────────────────────────
TIMESCALE_DSN=postgresql://verge:changeme@localhost:5433/verge_ts
# Optional: duplicate on API process to mirror readings into Timescale hypertable
# VERGE_TIMESCALE_DSN=postgresql://verge:changeme@localhost:5433/verge_ts

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=verge
# Require JWT on API routes when true (pair with Keycloak + console VITE_KEYCLOAK_URL)
VERGE_AUTH_ENABLED=false

# ── Verge API durable mode (host-side; pair with `make dev-sql`) ───────────────
# VERGE_STORE=sql
# VERGE_DB_URL=postgresql+psycopg://verge:YOUR_POSTGRES_PASSWORD@localhost:5432/verge
