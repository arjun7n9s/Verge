# =============================================================================
# Verge — environment template
# =============================================================================
# 1. Copy this file to `.env` in the repo root (never commit `.env`).
# 2. For Docker infra: also copy to `deploy/.env` (used by `make up`).
# 3. Export before running services, e.g. PowerShell:
#      Get-Content .env | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1], $matches[2], 'Process') } }
#    Or use direnv / dotenvx / your IDE env loader.
#
# Legend: [live] = wired in code today   [planned] = reserved for upcoming modules
# =============================================================================

# ── Site identity ─────────────────────────────────────────────────────────────
VERGE_SITE_ID=dev-plant-01
VERGE_SITE_NAME=Vizag Coke Oven (dev)
VERGE_ENV=development

# ── LLM (intelligence layer only — never used by risk-engine) [live] ─────────
# Provider: aimlapi | ollama | vllm | null
VERGE_LLM_PROVIDER=aimlapi
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
AIMLAPI_API_KEY=
VERGE_LLM_SYNTHESIS_MODEL=claude-sonnet-4-5
VERGE_LLM_CLASSIFIER_MODEL=meta-llama/Llama-3.1-8B-Instruct
# On-prem fallback (when VERGE_LLM_PROVIDER=ollama|vllm):
VERGE_LLM_BASE_URL=http://localhost:11434/v1
VERGE_LLM_API_KEY=
VERGE_LLM_TIMEOUT_S=20

# ── Cognee Cloud (incident/regulatory/plant memory) [planned] ─────────────────
VERGE_COGNEE_ENABLED=false
COGNEE_API_KEY=
COGNEE_BASE_URL=https://api.cognee.ai
# Dataset namespace per plant: verge-{VERGE_SITE_ID}
COGNEE_DATASET_PREFIX=verge

# ── Speechmatics (voice → structured evidence) [planned] ──────────────────────
VERGE_STT_PROVIDER=speechmatics
SPEECHMATICS_API_KEY=
SPEECHMATICS_BASE_URL=https://asr.api.speechmatics.com/v2
# Comma-separated BCP-47-ish codes for Indian plants:
SPEECHMATICS_LANGUAGES=en,hi,ta,te,kn
SPEECHMATICS_ENABLE_PARTIALS=false

# ── TTS for drafted alerts (optional — pick one provider) [planned] ───────────
VERGE_TTS_PROVIDER=
# Gradium:
GRADIUM_API_KEY=
GRADIUM_BASE_URL=
# Featherless:
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=

# ── API gateway [live] ────────────────────────────────────────────────────────
VERGE_API_HOST=0.0.0.0
VERGE_API_PORT=8000
# Store: memory (ephemeral dev) | sql (durable pilot/prod)
VERGE_STORE=memory
VERGE_DB_URL=sqlite:///verge.db
# Prod example:
# VERGE_STORE=sql
# VERGE_DB_URL=postgresql+psycopg://verge:changeme@localhost:5432/verge

# ── Stream bus [live CLI / planned full pipeline] ─────────────────────────────
REDPANDA_BROKERS=localhost:19092
VERGE_EVENTS_TOPIC=verge.events
VERGE_RISK_GROUP_ID=verge-risk-engine

# ── Postgres + PostGIS (permits, layout, geo) [infra live] ───────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=verge
POSTGRES_USER=verge
POSTGRES_PASSWORD=

# ── TimescaleDB (sensor time-series) [infra live] ───────────────────────────
TIMESCALE_DSN=postgresql://verge:changeme@localhost:5433/verge_ts

# ── Neo4j (equipment-permit-zone graph — optional; twin YAML used today) ──────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── MinIO (evidence packs, frames, reports) [infra live / app planned] ───────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=verge
MINIO_SECRET_KEY=
MINIO_BUCKET_EVIDENCE=verge-evidence
MINIO_USE_SSL=false

# ── Redis (async jobs, SSE fan-out) [infra live] ─────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Keycloak (OIDC / RBAC) [infra live / app planned] ─────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=verge
KEYCLOAK_CLIENT_ID=verge-console
KEYCLOAK_CLIENT_SECRET=
# API bearer validation (off by default; enable for pilot OIDC)
VERGE_AUTH_ENABLED=false

# ── Edge gateway [live] ───────────────────────────────────────────────────────
VERGE_MQTT_HOST=localhost
VERGE_MQTT_PORT=1883
VERGE_MQTT_TOPIC_PREFIX=verge/#

# Console (Vite) [live] ─────────────────────────────────────────────────────
# Dev uses Vite proxy; set only if API is on another host:
VITE_VERGE_API_URL=
# OIDC (optional — when set, console uses Keycloak login instead of dev auto-user)
VITE_KEYCLOAK_URL=
VITE_KEYCLOAK_REALM=verge
VITE_KEYCLOAK_CLIENT_ID=verge-console

# ── Staging / DMZ relay (optional — e.g. Vultr VM for pilot prep) [planned] ───
VERGE_STAGING_ENABLED=false
VERGE_STAGING_API_URL=
# VULTR_API_KEY=   # only if you automate staging infra; not read by Verge services

# ── Observability [planned] ───────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_MULTIPROC_DIR=

# ── CI / tests only ───────────────────────────────────────────────────────────
# VERGE_TEST_DB_URL=postgresql+psycopg://verge:verge@localhost:5432/verge
