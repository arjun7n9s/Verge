# ── Verge environment (copy to deploy/.env and fill) ──────────────────────────

# LLM provider: aimlapi | ollama | vllm | null
VERGE_LLM_PROVIDER=aimlapi
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
AIMLAPI_API_KEY=changeme
VERGE_LLM_SYNTHESIS_MODEL=claude-sonnet-4-5
VERGE_LLM_CLASSIFIER_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Stream bus
REDPANDA_BROKERS=localhost:19092

# Postgres + PostGIS (permits, layout, geo)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=verge
POSTGRES_USER=verge
POSTGRES_PASSWORD=verge

# TimescaleDB (sensor time-series)
TIMESCALE_DSN=postgresql://verge:verge@localhost:5433/verge_ts

# Neo4j (knowledge graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=vergeverge

# MinIO (evidence, frames, reports)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=verge
MINIO_SECRET_KEY=vergeverge

# Redis (jobs / fan-out)
REDIS_URL=redis://localhost:6379/0

# Keycloak (OIDC)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=verge
